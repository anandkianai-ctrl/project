<script>
// ── INIT LUCIDE ──────────────────────────────────────────────────────────────
document.addEventListener('DOMContentLoaded', () => {
  lucide.createIcons();
  buildHours();
});

// ── ROUTER ───────────────────────────────────────────────────────────────────
function navigate(page) {
  document.querySelectorAll('.page').forEach(p => p.classList.remove('active'));
  const el = document.getElementById('page-' + page);
  if (el) el.classList.add('active');
  document.querySelectorAll('.nav-link').forEach(l => {
    l.classList.toggle('active', l.dataset.page === page);
  });
  window.scrollTo({ top: 0, behavior: 'smooth' });
  lucide.createIcons();
}

// ── MOBILE MENU ──────────────────────────────────────────────────────────────
function toggleMobileMenu() {
  const m = document.getElementById('mobile-menu');
  m.classList.toggle('hidden');
  m.classList.toggle('flex');
}
function closeMobileMenu() {
  const m = document.getElementById('mobile-menu');
  m.classList.add('hidden');
  m.classList.remove('flex');
}

// ── HOURS ────────────────────────────────────────────────────────────────────
function buildHours() {
  const days = ['Monday','Tuesday','Wednesday','Thursday','Friday','Saturday','Sunday'];
  const list = document.getElementById('hours-list');
  if (!list) return;
  days.forEach(d => {
    const row = document.createElement('div');
    row.className = 'flex justify-between text-sm';
    row.innerHTML = `<span class="text-slate-400">${d}</span><span class="text-green-400 font-semibold">9:00 AM – 8:00 PM</span>`;
    list.appendChild(row);
  });
}

// ── CHAT WIDGET ──────────────────────────────────────────────────────────────
let chatHistory = [];
function toggleChat() {
  const win = document.getElementById('chat-window');
  const dot = document.getElementById('chat-dot');
  const icon = document.getElementById('chat-btn-icon');
  const isOpen = !win.classList.contains('hidden');
  win.classList.toggle('hidden', isOpen);
  win.style.display = isOpen ? 'none' : 'flex';
  dot.classList.toggle('hidden', !isOpen);
  icon.setAttribute('data-lucide', isOpen ? 'message-circle' : 'x');
  lucide.createIcons();
}

function appendChatMsg(role, text) {
  const container = document.getElementById('chat-messages');
  const wrap = document.createElement('div');
  wrap.className = 'flex gap-2' + (role === 'user' ? ' justify-end' : '');
  if (role === 'assistant') {
    wrap.innerHTML = `<div class="w-6 h-6 bg-orange-500 rounded-full flex items-center justify-center flex-shrink-0 mt-1"><i data-lucide="bot" class="w-3 h-3 text-white"></i></div><div class="bg-slate-700 text-slate-200 rounded-2xl px-3 py-2 text-xs max-w-xs leading-relaxed">${text}</div>`;
  } else {
    wrap.innerHTML = `<div class="bg-orange-500 text-white rounded-2xl px-3 py-2 text-xs max-w-xs leading-relaxed">${text}</div>`;
  }
  container.appendChild(wrap);
  container.scrollTop = container.scrollHeight;
  lucide.createIcons();
}

async function sendChat() {
  const inp = document.getElementById('chat-input');
  const txt = inp.value.trim();
  if (!txt) return;
  inp.value = '';
  appendChatMsg('user', txt);
  chatHistory.push({ role: 'user', content: txt });
  const typing = document.getElementById('chat-typing');
  typing.classList.remove('hidden');
  typing.style.display = 'flex';
  try {
    const res = await fetch('https://api.anthropic.com/v1/messages', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        model: 'claude-sonnet-4-20250514',
        max_tokens: 1000,
        system: `You are a friendly, knowledgeable service advisor at Quick Fix Auto Limited in Vancouver, BC. Address: 8655 Cambie St., Unit 3, Vancouver, BC V6P 3J9. Phone: +1 604-441-4006. Hours: 9AM–8PM every day. Services: Advanced diagnostics (OBD-II scanning), radiator/cooling system repair, general auto repair (brakes, oil changes, tune-ups, suspension, electrical). Pricing guidance: Oil change ~$60–$90, brake pads ~$150–$250/axle, diagnostics ~$80–$120, radiator flush ~$100–$150. Always note final pricing needs in-person assessment. Be helpful, warm, concise (2–3 sentences max). Encourage booking or calling for specific quotes.`,
        messages: chatHistory
      })
    });
    const data = await res.json();
    const reply = data.content?.map(b => b.text || '').join('') || 'Please call us at +1 604-441-4006!';
    chatHistory.push({ role: 'assistant', content: reply });
    typing.classList.add('hidden');
    typing.style.display = 'none';
    appendChatMsg('assistant', reply);
  } catch {
    typing.classList.add('hidden');
    typing.style.display = 'none';
    appendChatMsg('assistant', 'Sorry, having trouble connecting. Please call +1 604-441-4006!');
  }
}

// ── QUOTE FORM ───────────────────────────────────────────────────────────────
async function submitQuote() {
  const name = document.getElementById('q-name').value.trim();
  const phone = document.getElementById('q-phone').value.trim();
  const car = document.getElementById('q-car').value.trim();
  const service = document.getElementById('q-service').value;
  const notes = document.getElementById('q-notes').value.trim();
  if (!name || !phone || !car || !service) return;

  document.getElementById('quote-form').classList.add('hidden');
  const resp = document.getElementById('quote-response');
  resp.classList.remove('hidden');
  resp.style.display = 'flex';
  resp.style.flexDirection = 'column';

  const loading = document.getElementById('quote-loading');
  loading.classList.remove('hidden');
  loading.style.display = 'flex';

  const userText = `Quote request — Name: ${name}, Phone: ${phone}, Vehicle: ${car}, Service: ${service}${notes ? ', Notes: ' + notes : ''}`;
  const msgDiv = document.getElementById('quote-messages');
  // user bubble
  const userWrap = document.createElement('div');
  userWrap.className = 'flex gap-3 items-end flex-row-reverse';
  userWrap.innerHTML = `<div class="bg-orange-500 text-white rounded-2xl px-4 py-3 text-sm max-w-sm leading-relaxed">${userText}</div>`;
  msgDiv.appendChild(userWrap);

  try {
    const res = await fetch('https://api.anthropic.com/v1/messages', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        model: 'claude-sonnet-4-20250514',
        max_tokens: 1000,
        system: `You are a friendly service advisor at Quick Fix Auto Limited, Vancouver, BC. Address: 8655 Cambie St., Unit 3. Phone: +1 604-441-4006. Hours: 9AM–8PM every day. Respond to quote requests warmly and professionally. Acknowledge their name and vehicle, give a helpful pricing estimate (note final price needs in-person assessment), mention same-day availability, and invite them to call or come in. Keep to 4–5 sentences. Sign off as "— The Quick Fix Auto Team 🔧"`,
        messages: [{ role: 'user', content: userText }]
      })
    });
    const data = await res.json();
    const reply = data.content?.map(b => b.text || '').join('') || 'Thanks! Please call +1 604-441-4006 for your quote.';
    loading.classList.add('hidden');
    const aiWrap = document.createElement('div');
    aiWrap.className = 'flex gap-3 items-start';
    aiWrap.innerHTML = `<div class="w-9 h-9 rounded-full bg-blue-600 flex items-center justify-center flex-shrink-0"><i data-lucide="bot" class="w-4 h-4 text-white"></i></div><div class="bg-slate-700 text-slate-200 rounded-2xl px-4 py-3 text-sm max-w-sm leading-relaxed">${reply}</div>`;
    msgDiv.appendChild(aiWrap);
    document.getElementById('quote-actions').classList.remove('hidden');
    document.getElementById('quote-actions').style.display = 'flex';
    lucide.createIcons();
  } catch {
    loading.classList.add('hidden');
    const aiWrap = document.createElement('div');
    aiWrap.innerHTML = `<div class="bg-slate-700 text-slate-200 rounded-2xl px-4 py-3 text-sm">Thanks for reaching out! Please call us at <a href="tel:+16044414006" class="text-orange-400">+1 604-441-4006</a> for your quote.</div>`;
    msgDiv.appendChild(aiWrap);
  }
}

function resetQuote() {
  document.getElementById('q-name').value = '';
  document.getElementById('q-phone').value = '';
  document.getElementById('q-car').value = '';
  document.getElementById('q-service').value = '';
  document.getElementById('q-notes').value = '';
  document.getElementById('quote-messages').innerHTML = '';
  document.getElementById('quote-response').classList.add('hidden');
  document.getElementById('quote-actions').classList.add('hidden');
  document.getElementById('quote-form').classList.remove('hidden');
}
</script>
