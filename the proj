<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width,initial-scale=1"/>
<title>Fraserview Collision Repair | Vancouver Auto Body Shop</title>
<meta name="description" content="Vancouver's trusted collision repair shop. Expert body, paint & frame work on all makes and models. ICBC accepted. Free estimates. Est. 1994."/>
<script src="https://cdn.tailwindcss.com"></script>
<style>
  :root{--red:#c0392b;--dark:#0d0d0d;--darker:#080808;--card:#161616;--border:#222;--text:#e0e0e0;--muted:#888;}
  *{box-sizing:border-box;margin:0;padding:0;}
  html{scroll-behavior:smooth;}
  body{background:var(--dark);color:var(--text);font-family:'Segoe UI',Arial,sans-serif;overflow-x:hidden;}

  nav{position:fixed;top:0;width:100%;z-index:1000;background:rgba(8,8,8,.95);backdrop-filter:blur(10px);border-bottom:1px solid var(--border);padding:0 2rem;}
  .nav-inner{max-width:1200px;margin:0 auto;display:flex;align-items:center;justify-content:space-between;height:64px;}
  .logo{font-size:1.2rem;font-weight:800;color:#fff;letter-spacing:.5px;}
  .logo span{color:var(--red);}
  .nav-links{display:flex;gap:2rem;list-style:none;}
  .nav-links a{color:var(--muted);text-decoration:none;font-size:.9rem;font-weight:500;transition:color .2s;cursor:pointer;}
  .nav-links a:hover,.nav-links a.active{color:#fff;}
  .nav-cta{background:var(--red);color:#fff;border:none;padding:.55rem 1.3rem;border-radius:4px;font-weight:600;font-size:.85rem;cursor:pointer;transition:background .2s;}
  .nav-cta:hover{background:#a93226;}

  .page{display:none;min-height:100vh;padding-top:64px;}
  .page.active{display:block;}

  .hero{min-height:100vh;display:flex;align-items:center;justify-content:center;overflow:hidden;background:radial-gradient(ellipse at 60% 50%,#1a0a0a 0%,var(--darker) 70%);}
  .hero-content{text-align:center;z-index:2;position:relative;padding:2rem;}
  .hero-badge{display:inline-block;background:rgba(192,57,43,.15);border:1px solid rgba(192,57,43,.4);color:var(--red);padding:.4rem 1rem;border-radius:20px;font-size:.8rem;font-weight:600;letter-spacing:1px;margin-bottom:1.5rem;text-transform:uppercase;}
  .hero h1{font-size:clamp(2.5rem,6vw,4.5rem);font-weight:900;line-height:1.1;color:#fff;margin-bottom:1rem;}
  .hero h1 span{color:var(--red);}
  .hero p{font-size:1.1rem;color:var(--muted);max-width:560px;margin:0 auto 2.5rem;}
  .hero-btns{display:flex;gap:1rem;justify-content:center;flex-wrap:wrap;}
  .btn-primary{background:var(--red);color:#fff;padding:.8rem 2rem;border-radius:5px;font-weight:700;font-size:.95rem;cursor:pointer;border:none;transition:all .2s;}
  .btn-primary:hover{background:#a93226;transform:translateY(-1px);}
  .btn-outline{background:transparent;color:#fff;padding:.8rem 2rem;border-radius:5px;font-weight:600;font-size:.95rem;cursor:pointer;border:1px solid #444;transition:all .2s;}
  .btn-outline:hover{border-color:#fff;}
  .car-scene{width:min(600px,90vw);margin:3rem auto 0;}
  .car-scene svg{width:100%;filter:drop-shadow(0 20px 60px rgba(192,57,43,.3));}

  .reveal{opacity:0;transform:translateY(40px);transition:opacity .7s ease,transform .7s ease;}
  .reveal.visible{opacity:1;transform:none;}
  .reveal-left{opacity:0;transform:translateX(-50px);transition:opacity .7s ease,transform .7s ease;}
  .reveal-left.visible{opacity:1;transform:none;}
  .reveal-right{opacity:0;transform:translateX(50px);transition:opacity .7s ease,transform .7s ease;}
  .reveal-right.visible{opacity:1;transform:none;}

  .section{padding:6rem 2rem;max-width:1200px;margin:0 auto;}
  .section-label{font-size:.75rem;font-weight:700;letter-spacing:2px;text-transform:uppercase;color:var(--red);margin-bottom:.75rem;}
  .section-title{font-size:clamp(1.8rem,4vw,2.8rem);font-weight:900;color:#fff;margin-bottom:1rem;}
  .divider{width:50px;height:3px;background:var(--red);margin:1rem 0 2rem;}

  .about-grid{display:grid;grid-template-columns:1fr 1fr;gap:4rem;align-items:center;margin-top:3rem;}
  @media(max-width:768px){.about-grid,.location-grid{grid-template-columns:1fr;}}

  .services-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(300px,1fr));gap:2rem;margin-top:3rem;}
  .service-card{background:var(--card);border:1px solid var(--border);border-radius:12px;overflow:hidden;transition:transform .3s,border-color .3s;}
  .service-card:hover{transform:translateY(-6px);border-color:var(--red);}
  .service-car-wrap{padding:2rem 2rem 0;display:flex;justify-content:center;}
  .service-car-wrap svg{width:180px;filter:drop-shadow(0 8px 20px rgba(192,57,43,.2));}
  .service-info{padding:1.5rem 2rem 2rem;}
  .service-info h3{font-size:1.2rem;font-weight:800;color:#fff;margin-bottom:.5rem;}
  .service-info p{color:var(--muted);font-size:.9rem;line-height:1.7;}
  .service-tag{display:inline-block;margin-top:.75rem;background:rgba(192,57,43,.12);color:var(--red);border:1px solid rgba(192,57,43,.3);padding:.25rem .75rem;border-radius:20px;font-size:.75rem;font-weight:600;}

  .reviews-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(300px,1fr));gap:1.5rem;margin-top:3rem;}
  .review-card{background:var(--card);border:1px solid var(--border);border-radius:12px;padding:1.75rem;transition:border-color .3s;}
  .review-card:hover{border-color:rgba(192,57,43,.5);}
  .stars{color:#f0c040;font-size:1rem;margin-bottom:.75rem;letter-spacing:2px;}
  .review-text{color:#ccc;font-size:.92rem;line-height:1.75;font-style:italic;margin-bottom:1rem;}
  .reviewer{display:flex;align-items:center;gap:.75rem;}
  .avatar{width:40px;height:40px;border-radius:50%;background:var(--red);display:flex;align-items:center;justify-content:center;font-weight:800;color:#fff;font-size:.9rem;flex-shrink:0;}
  .reviewer-name{font-weight:700;color:#fff;font-size:.9rem;}
  .reviewer-source{font-size:.75rem;color:var(--muted);}
  .rating-summary{background:var(--card);border:1px solid var(--border);border-radius:12px;padding:2rem;margin-bottom:2rem;display:flex;align-items:center;gap:3rem;flex-wrap:wrap;}
  .big-score{font-size:4rem;font-weight:900;color:#fff;line-height:1;}

  .location-grid{display:grid;grid-template-columns:1fr 1fr;gap:3rem;margin-top:3rem;align-items:start;}
  .info-block{background:var(--card);border:1px solid var(--border);border-radius:12px;padding:2rem;margin-bottom:1.5rem;}
  .info-block h4{font-size:.75rem;letter-spacing:2px;text-transform:uppercase;color:var(--red);margin-bottom:1rem;}
  .info-row{display:flex;gap:1rem;align-items:flex-start;margin-bottom:.75rem;}
  .info-text{color:var(--text);font-size:.95rem;line-height:1.5;}
  .hours-table{width:100%;}
  .hours-table tr{border-bottom:1px solid var(--border);}
  .hours-table td{padding:.6rem 0;font-size:.9rem;color:var(--text);}
  .hours-table td:last-child{text-align:right;color:var(--muted);}

  .contact-section{padding:6rem 2rem;background:var(--dark);}
  .contact-inner{max-width:700px;margin:0 auto;}
  .form-group{margin-bottom:1.25rem;}
  .form-group label{display:block;font-size:.85rem;color:var(--muted);font-weight:600;margin-bottom:.4rem;}
  .form-group input,.form-group textarea,.form-group select{width:100%;background:#111;border:1px solid var(--border);border-radius:6px;padding:.8rem 1rem;color:var(--text);font-size:.95rem;transition:border-color .2s;outline:none;}
  .form-group input:focus,.form-group textarea:focus,.form-group select:focus{border-color:var(--red);}
  .form-group textarea{resize:vertical;min-height:120px;}
  .form-group select option{background:#111;}
  .form-row{display:grid;grid-template-columns:1fr 1fr;gap:1rem;}
  @media(max-width:600px){.form-row{grid-template-columns:1fr;}}
  .submit-btn{width:100%;background:var(--red);color:#fff;border:none;padding:1rem;border-radius:6px;font-size:1rem;font-weight:700;cursor:pointer;transition:background .2s;margin-top:.5rem;}
  .submit-btn:hover{background:#a93226;}
  .submit-btn:disabled{opacity:.6;cursor:not-allowed;}
  .success-msg{display:none;background:rgba(39,174,96,.1);border:1px solid rgba(39,174,96,.3);color:#2ecc71;padding:1rem;border-radius:8px;text-align:center;margin-top:1rem;}
  .error-msg{display:none;background:rgba(192,57,43,.1);border:1px solid rgba(192,57,43,.3);color:#e74c3c;padding:1rem;border-radius:8px;text-align:center;margin-top:1rem;}

  .chat-widget{position:fixed;bottom:2rem;right:2rem;z-index:999;}
  .chat-btn{width:60px;height:60px;border-radius:50%;background:var(--red);border:none;cursor:pointer;display:flex;align-items:center;justify-content:center;box-shadow:0 4px 20px rgba(192,57,43,.5);transition:transform .2s;}
  .chat-btn:hover{transform:scale(1.1);}
  .chat-btn svg{width:28px;height:28px;fill:#fff;}
  .chat-panel{display:none;position:absolute;bottom:75px;right:0;width:360px;background:#111;border:1px solid var(--border);border-radius:16px;overflow:hidden;box-shadow:0 20px 60px rgba(0,0,0,.7);flex-direction:column;}
  .chat-panel.open{display:flex;}
  .chat-header{background:var(--red);padding:1rem 1.25rem;display:flex;justify-content:space-between;align-items:center;}
  .chat-header-info{display:flex;align-items:center;gap:.75rem;}
  .chat-av{width:36px;height:36px;border-radius:50%;background:rgba(255,255,255,.2);display:flex;align-items:center;justify-content:center;font-size:1.1rem;}
  .chat-title-txt{font-weight:700;color:#fff;font-size:.95rem;}
  .chat-subtitle{font-size:.72rem;color:rgba(255,255,255,.7);}
  .chat-close{background:none;border:none;color:#fff;font-size:1.3rem;cursor:pointer;opacity:.8;}
  .chat-close:hover{opacity:1;}
  .chat-messages{height:320px;overflow-y:auto;padding:1rem;display:flex;flex-direction:column;gap:.75rem;}
  .chat-messages::-webkit-scrollbar{width:4px;}
  .chat-messages::-webkit-scrollbar-thumb{background:#333;border-radius:2px;}
  .msg{max-width:82%;padding:.7rem 1rem;border-radius:12px;font-size:.88rem;line-height:1.5;}
  .msg.bot{background:#1e1e1e;color:var(--text);border-bottom-left-radius:3px;align-self:flex-start;}
  .msg.user{background:var(--red);color:#fff;border-bottom-right-radius:3px;align-self:flex-end;}
  .msg.typing{background:#1e1e1e;align-self:flex-start;}
  .typing-dots{display:flex;gap:4px;align-items:center;height:20px;}
  .typing-dots span{width:7px;height:7px;border-radius:50%;background:var(--muted);animation:bounce .9s infinite;}
  .typing-dots span:nth-child(2){animation-delay:.2s;}
  .typing-dots span:nth-child(3){animation-delay:.4s;}
  @keyframes bounce{0%,60%,100%{transform:translateY(0);}30%{transform:translateY(-6px);}}
  .chat-input-row{display:flex;gap:.5rem;padding:.75rem 1rem;border-top:1px solid var(--border);}
  .chat-input{flex:1;background:#1a1a1a;border:1px solid var(--border);border-radius:8px;padding:.6rem .9rem;color:var(--text);font-size:.88rem;outline:none;}
  .chat-input:focus{border-color:var(--red);}
  .chat-send{background:var(--red);border:none;border-radius:8px;padding:.6rem .9rem;cursor:pointer;color:#fff;font-size:1rem;}
  .chat-send:hover{background:#a93226;}

  footer{background:var(--darker);border-top:1px solid var(--border);padding:3rem 2rem;text-align:center;}
  .footer-logo{font-size:1.3rem;font-weight:900;color:#fff;margin-bottom:.5rem;}
  .footer-logo span{color:var(--red);}
  .footer-links{display:flex;gap:2rem;justify-content:center;flex-wrap:wrap;margin:1.5rem 0;}
  .footer-links a{color:var(--muted);text-decoration:none;font-size:.85rem;cursor:pointer;transition:color .2s;}
  .footer-links a:hover{color:#fff;}

  @media(max-width:600px){.nav-links{display:none;}.chat-panel{width:calc(100vw - 2rem);right:-1rem;}}
</style>
</head>
