  <button class="chat-btn" onclick="toggleChat()">
    <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M12 2C6.48 2 2 6.03 2 11c0 2.64 1.19 5.01 3.08 6.71L4 22l4.44-1.48C9.55 20.83 10.75 21 12 21c5.52 0 10-4.03 10-9S17.52 2 12 2z"/></svg>
  </button>
</div>

<script>
// ─── CONFIG ────────────────────────────────────────────────
// Replace with your actual Anthropic API key.
// Move to a backend proxy before going public!
const ANTHROPIC_API_KEY = 'YOUR_ANTHROPIC_API_KEY';
// ───────────────────────────────────────────────────────────

// PAGE NAVIGATION
function showPage(p) {
  document.querySelectorAll('.page').forEach(pg => pg.classList.remove('active'));
  document.getElementById(p + '-page').classList.add('active');
  document.querySelectorAll('.nav-links a').forEach(a => a.classList.remove('active'));
  const n = document.getElementById('nav-' + p);
  if (n) n.classList.add('active');
  window.scrollTo(0, 0);
  setTimeout(observeReveal, 100);
}

function goContact() {
  showPage('location');
  setTimeout(() => document.getElementById('contact-anchor').scrollIntoView({ behavior: 'smooth' }), 200);
}

// SCROLL REVEAL
function observeReveal() {
  const els = document.querySelectorAll('.reveal:not(.visible),.reveal-left:not(.visible),.reveal-right:not(.visible)');
  const obs = new IntersectionObserver(entries => {
    entries.forEach(e => { if (e.isIntersecting) { e.target.classList.add('visible'); obs.unobserve(e.target); } });
  }, { threshold: 0.12 });
  els.forEach(el => obs.observe(el));
}
document.addEventListener('DOMContentLoaded', () => setTimeout(observeReveal, 100));
window.addEventListener('scroll', observeReveal);

// CONTACT FORM (Formspree)
document.getElementById('quoteForm').addEventListener('submit', async function(e) {
  e.preventDefault();
  const btn = document.getElementById('submitBtn');
  btn.disabled = true;
  btn.textContent = 'Sending...';
  document.getElementById('success-msg').style.display = 'none';
  document.getElementById('error-msg').style.display = 'none';
  try {
    const res = await fetch(this.action, {
      method: 'POST',
      body: new FormData(this),
      headers: { 'Accept': 'application/json' }
    });
    if (res.ok) {
      document.getElementById('success-msg').style.display = 'block';
      this.reset();
    } else {
      document.getElementById('error-msg').style.display = 'block';
    }
  } catch (err) {
    document.getElementById('error-msg').style.display = 'block';
  }
  btn.disabled = false;
  btn.textContent = 'Send Request →';
});

// AI CHAT
function toggleChat() {
  const p = document.getElementById('chatPanel');
  p.classList.toggle('open');
  if (p.classList.contains('open')) document.getElementById('chatInput').focus();
}

const SYS = `You are a helpful AI assistant for Fraserview Collision Repair, a trusted auto body shop in Vancouver, BC.
Key facts:
- Address: 8225 Chester St, Vancouver, BC V5X 4P6
- Phone: (604) 327-9229
- Hours: Mon-Fri 7:30am-5:30pm, Sat 9am-2pm, Sun Closed
- Founded 1994 by Rick and Ali Habib
- Services: auto body repair, paint & refinishing, frame straightening, SUV/van/truck repair, windshield repair, ICBC claims, auto detailing
- Courtesy/loaner cars from day one
- Free estimates, no hidden fees
- ICBC recommended and accepted
- Team includes Sam (manager), Sarah (front desk)
- Repairs typically done within a week
Be friendly and concise. Keep replies under 3 sentences unless detail is needed. Always encourage booking a free estimate or calling (604) 327-9229.`;

let hist = [];

async function sendChat() {
  const inp = document.getElementById('chatInput');
  const msg = inp.value.trim();
  if (!msg) return;
  inp.value = '';
  addMsg(msg, 'user');
  hist.push({ role: 'user', content: msg });
  const t = addTyping();
  try {
    const r = await fetch('https://api.anthropic.com/v1/messages', {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
        'x-api-key': ANTHROPIC_API_KEY,
        'anthropic-version': '2023-06-01',
        'anthropic-dangerous-allow-browser': 'true'
      },
      body: JSON.stringify({ model: 'claude-sonnet-4-20250514', max_tokens: 1000, system: SYS, messages: hist })
    });
    const d = await r.json();
    t.remove();
    const rep = d.content?.map(c => c.text || '').join('') || "Sorry, I'm having trouble. Please call (604) 327-9229!";
    hist.push({ role: 'assistant', content: rep });
    addMsg(rep, 'bot');
  } catch (err) {
    t.remove();
    addMsg("Sorry, I'm having trouble connecting. Please call us at (604) 327-9229!", 'bot');
  }
}

function addMsg(text, type) {
  const m = document.getElementById('chatMessages');
  const d = document.createElement('div');
  d.className = 'msg ' + type;
  d.textContent = text;
  m.appendChild(d);
  m.scrollTop = m.scrollHeight;
  return d;
}

function addTyping() {
  const m = document.getElementById('chatMessages');
  const d = document.createElement('div');
  d.className = 'msg typing';
  d.innerHTML = '<div class="typing-dots"><span></span><span></span><span></span></div>';
  m.appendChild(d);
  m.scrollTop = m.scrollHeight;
  return d;
}
</script>
